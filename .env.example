# =============================================================================
# Incidex Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# Required: OpenAI API Key
# =============================================================================
# Get your API key from: https://platform.openai.com/api-keys
# This is required for GPT-4 incident extraction from news articles.
OPENAI_API_KEY=sk-your-api-key-here

# =============================================================================
# Optional: Processing Settings
# =============================================================================
# Number of articles to process in each batch (default: 50)
# BATCH_SIZE=50

# Delay between API requests in seconds for rate limiting (default: 1)
# RATE_LIMIT_DELAY=1

# Maximum concurrent requests for async operations (default: 8)
# MAX_CONCURRENT_REQUESTS=8

# Hours of articles to fetch by default (default: 24)
# DEFAULT_HOURS_BACK=24

# =============================================================================
# Optional: Community Reports
# =============================================================================
# Secret key for signing approval tokens (HMAC)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REPORT_SIGNING_KEY=your-secret-signing-key-here

# Base URL for the Incidex site (used in email links)
# INCIDEX_BASE_URL=https://incidex.au

# Comma-separated list of reviewer email addresses
# REVIEWER_EMAILS=reviewer1@example.com,reviewer2@example.com

# =============================================================================
# Optional: Email Settings (SMTP)
# =============================================================================
# SMTP server configuration for sending emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@incidex.au
# SMTP_USE_TLS=true

# =============================================================================
# Optional: Discord Alerts
# =============================================================================
# Discord webhook URL for sending alerts about new incidents
# Create a webhook in Discord: Server Settings > Integrations > Webhooks
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# =============================================================================
# Optional: Google APIs
# =============================================================================
# Google API Key for Gemini (alternative to OpenAI for incident extraction)
# GOOGLE_API_KEY=your-google-api-key-here

# Google Maps API Key for geocoding fallback
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# =============================================================================
# Optional: Feature Flags
# =============================================================================
# Enable debug mode for more verbose logging
# DEBUG_MODE=false

# Enable dry-run mode by default (don't save changes)
# DRY_RUN_DEFAULT=false
